{
  "name": "exilelens-kr",
  "productName": "ExileLens KR",
  "version": "0.1.0",
  "description": "POE2 Korean overlay for item price checks and area-aware quest checklists.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "author": "ExileLens KR contributors",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "npm run build && electron-builder --win dir --publish=never",
    "dist": "npm run build && electron-builder --win zip --publish=never",
    "package:smoke": "node scripts/smoke-package.mjs",
    "ci": "npm run typecheck && npm test && npm run build && npm run package:smoke",
    "audit:low": "npm audit --audit-level=low",
    "dist:smoke": "npm run dist && npm run package:smoke"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "latest",
    "vite": "^7.3.5",
    "vitest": "latest"
  },
  "build": {
    "appId": "kr.exilelens.overlay",
    "productName": "ExileLens KR",
    "directories": {
      "buildResources": "buildResources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "compression": "normal",
    "win": {
      "target": [
        "dir",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "npmRebuild": false
  },
  "overrides": {
    "vite": {
      "esbuild": "0.28.1"
    }
  }
}
